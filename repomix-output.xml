    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 16px;
    padding: 40px;
    max-width: 500px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(102, 126, 234, 0.5);
    animation: slideUp 0.3s ease;
    text-align: center;
    color: white;
}

