    "secondary_color": "#764ba2",
    "success_color": "#00ff00",
    "error_color": "#ff5555",
    "warning_color": "#ffaa00"
  },
  },
  },
  },
  "audio_feedback": {
    "enabled": true,
    "verbosity": "normal",
    "volume": 0.7,
    "events": {
      "start": "sounds/[lang]/start.mp3",
