{
  "analytics": true,
  "appearance": {
    "default_theme": "light"
  },
  "branding": {
    "logo": "images/powered-logo.png",
    "logo_dark": "images/powered-logo-dark.png",
    "favicon": "images/favicon.ico"
  },
  "languages": [
    {
      "code": "en",
      "name": "English",
      "default": true
    }
  ],
  "links": {
    "github": {
      "enabled": true,
      "url": "https://github.com/luc-github/esp3d-webinstaller/issues/new"
    }
  },
  "footer": {
    "enabled": true,
    "links": [
      {
        "key": "privacyPolicy",
        "url": "privacy.html"
      },
      {
        "key": "termsOfService",
        "url": "terms.html"
      }
    ]
  },
  "browser_compatibility": {
    "show_warning": true,
    "supported_browsers": ["Chrome", "Edge", "Opera"]
  },
  "flash_baudrate": {
    "options": [921600, 460800, 230400, 115200],
    "default": 921600
  },
  "serial_monitor": {
    "options": [2000000, 1500000, 1000000, 921600, 460800, 230400, 115200, 74880, 57600, 38400, 19200, 9600],
    "default": 115200
  },
  "firmware_versions": {
    "enabled": true,
    "tag_presets": {
      "latest": { "icon": "⭐", "short": "Latest" },
      "last": { "icon": "⭐", "short": "Last" },
      "stable": { "icon": "✓", "short": "Stable" },
      "new": { "icon": "✨", "short": "New" },
      "preview": { "icon": "🔭", "short": "Preview" },
      "beta": { "icon": "🧪", "short": "Beta" },
      "legacy": { "icon": "📦", "short": "Legacy" },
      "rc": { "icon": "◉", "short": "RC" }
    }
  },
  "theme": {
    "primary_color": "#667eea",
    "secondary_color": "#764ba2",
    "success_color": "#00ff00",
    "error_color": "#ff5555",
    "warning_color": "#ffaa00"
  },
  "error_logging": {
    "enabled": true,
    "categories": {
      "user_cancel": false,
      "port_busy": true,
      "connection_timeout": true,
      "download_failed": true,
      "hardware_error": true,
      "wrong_browser": false,
      "flash_error": true,
      "unknown": true
    }
  },
   "audio_feedback": {
    "enabled": false,
    "verbosity": "verbose",
    "volume": 0.7,
    "events": {
      "start": "",
      "dialog_open": "sounds/[lang]/select-port.mp3",
      "port_selected": "sounds/[lang]/port-selected.mp3",
      "boot_prompt": "sounds/[lang]/press-boot.mp3",
      "connecting": "sounds/[lang]/connecting.mp3",
      "connected": "sounds/[lang]/connected.mp3",
      "erasing": "",
      "erase_complete": "",
      "flashing_start": "sounds/[lang]/flashing-start.mp3",
      "flashing_progress": "sounds/[lang]/progress.mp3",
      "writing_complete": "",
      "rebooting": "",
      "success": "sounds/[lang]/success.mp3",
      "error": "sounds/[lang]/error.mp3",
      "error_user_cancel": "sounds/[lang]/cancel.mp3",
      "error_connection_timeout": "sounds/[lang]/timeout.mp3",
      "error_port_busy": "sounds/[lang]/busy.mp3",
      "error_hardware_error": "sounds/[lang]/hardware-error.mp3",
      "error_download_failed": "sounds/[lang]/download-error.mp3",
      "error_wrong_browser": "sounds/[lang]/browser-error.mp3",
      "error_flash_error": "sounds/[lang]/flash-error.mp3"
      
    }
  }
}
