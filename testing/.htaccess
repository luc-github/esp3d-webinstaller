RewriteEngine On

# === Force HTTPS ===
RewriteCond %{ENV:HTTPS} !on
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ==============================================================
# === MODE MAINTENANCE (activé uniquement si le fichier existe) ===
# ==============================================================
# Pour activer  → créer un fichier vide nommé ".maintenance" à la racine
# Pour désactiver → supprimer ce fichier
RewriteCond %{DOCUMENT_ROOT}/.maintenance -f

# Exception : ton IP (remplace par la tienne)
RewriteCond %{REMOTE_ADDR} !^114\.37\.135\.124$

# On ne redirige jamais la page maintenance elle-même
RewriteCond %{REQUEST_URI} !^/maintenance\.html$ [NC]

# On laisse passer les fichiers CSS/JS/images (sinon la page maintenance est cassée)
RewriteCond %{REQUEST_URI} !\.(css|js|jpg|jpeg|png|gif|ico|svg|webp|woff|woff2|ttf|eot|otf)$ [NC]

# Redirection temporaire vers la maintenance
RewriteRule ^ /maintenance.html [R=302,L]

# ==============================================================
# === Désactive le cache (toujours actif) ===
# ==============================================================
<FilesMatch "\.(html|css|js|json|bin)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>
